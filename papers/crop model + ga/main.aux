\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Applied versus absorbed nutrients under the baseline farmer strategy. The delayed absorption dynamics are evident in the lag between applied inputs and the smoothed absorbed signals. Water absorption ($\sigma _w = 30$ hr) responds more quickly than fertilizer absorption ($\sigma _f = 300$ hr).}}{34}{figure.5}\protected@file@percent }
\newlabel{fig:applied-absorbed}{{5}{34}{Applied versus absorbed nutrients under the baseline farmer strategy. The delayed absorption dynamics are evident in the lag between applied inputs and the smoothed absorbed signals. Water absorption ($\sigma _w = 30$ hr) responds more quickly than fertilizer absorption ($\sigma _f = 300$ hr)}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Cumulative absorbed nutrients (solid) versus expected levels (dashed red). The growing gap between actual and expected water absorption reflects the drought stress accumulating over the season. Fertilizer applications maintain closer alignment with expectations.}}{35}{figure.6}\protected@file@percent }
\newlabel{fig:cumulative}{{6}{35}{Cumulative absorbed nutrients (solid) versus expected levels (dashed red). The growing gap between actual and expected water absorption reflects the drought stress accumulating over the season. Fertilizer applications maintain closer alignment with expectations}{figure.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Instantaneous divergence from expected cumulative nutrient levels. Higher divergence indicates greater stress.}}{36}{figure.7}\protected@file@percent }
\newlabel{fig:divergence}{{7}{36}{Instantaneous divergence from expected cumulative nutrient levels. Higher divergence indicates greater stress}{figure.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Nutrient factor evolution under the baseline scenario. The water nutrient factor $\nu _w$ declines due to cumulative drought stress, while fertilizer, temperature, and radiation factors remain closer to 1.0 (no stress). The declining $\nu _w$ (which later recovers) reduces effective growth rates and carrying capacities throughout the season.}}{37}{figure.8}\protected@file@percent }
\newlabel{fig:nutrient-factors}{{8}{37}{Nutrient factor evolution under the baseline scenario. The water nutrient factor $\nu _w$ declines due to cumulative drought stress, while fertilizer, temperature, and radiation factors remain closer to 1.0 (no stress). The declining $\nu _w$ (which later recovers) reduces effective growth rates and carrying capacities throughout the season}{figure.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces GA convergence across 10 independent runs. Each curve shows the best revenue at each generation. All runs exhibit rapid improvement in early generations followed by convergence to near-optimal solutions. The consistency across runs demonstrates algorithm robustness.}}{38}{figure.9}\protected@file@percent }
\newlabel{fig:ga-convergence}{{9}{38}{GA convergence across 10 independent runs. Each curve shows the best revenue at each generation. All runs exhibit rapid improvement in early generations followed by convergence to near-optimal solutions. The consistency across runs demonstrates algorithm robustness}{figure.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Plant state variable trajectories for the best member from each of the 10 independent GA runs. All optimized strategies achieve similar, near-optimal growth trajectories, and 9 of 10 runs substantially outperform the baseline farmer practices (Figure \ref  {fig:baseline-growth}). The tight clustering of trajectories demonstrates that different GA runs converge to similar optimal strategies.}}{39}{figure.10}\protected@file@percent }
\newlabel{fig:state-trajectories}{{10}{39}{Plant state variable trajectories for the best member from each of the 10 independent GA runs. All optimized strategies achieve similar, near-optimal growth trajectories, and 9 of 10 runs substantially outperform the baseline farmer practices (Figure \ref {fig:baseline-growth}). The tight clustering of trajectories demonstrates that different GA runs converge to similar optimal strategies}{figure.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Plant state variable trajectories for the worst member from each GA run's final population. These suboptimal strategies achieve almost no growth, providing a sanity check on the model that excellent growth is not guaranteed. }}{40}{figure.11}\protected@file@percent }
\newlabel{fig:worst}{{11}{40}{Plant state variable trajectories for the worst member from each GA run's final population. These suboptimal strategies achieve almost no growth, providing a sanity check on the model that excellent growth is not guaranteed}{figure.11}{}}
